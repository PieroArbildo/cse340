<h1><%= title %></h1>
<%- messages() %>

<form action="/account/register" method="POST">
    <div>
        <label for="firstName">First Name:</label>
        <input type="text" id="firstName" name="account_firstname" required data-trail="First Name">
    </div>
    <div>
        <label for="lastName">Last Name:</label>
        <input type="text" id="lastName" name="account_lastname" required data-trail="Last Name">
    </div>
    <div>
        <label for="email">Email Address:</label>
        <input type="email" id="email" name="account_email" required data-trail="Email">
    </div>
    <div>
        <label for="password">Password:</label>
        <input type="password" id="password" name="account_password" required data-trail="Password">
        <small>Password must be at least 12 characters long, contain at least 1 uppercase letter, 1 number, and 1 special character.</small>
    </div>
    <button type="submit">Register</button>
</form>